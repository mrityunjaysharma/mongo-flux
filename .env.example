# MongoFlux Configuration
# Copy to .env and override values for your environment.
# All values below are defaults — only set what you need to change.

# MongoDB
MG_MONGO_URI=mongodb://localhost:27017/?replicaSet=rs0
MG_MONGO_DB=myapp

# ClickHouse
MG_CH_HOST=localhost
MG_CH_PORT=8123
MG_CH_DB=analytics
MG_CH_USER=default
MG_CH_PASSWORD=

# Sync
MG_SYNC_MODE=oplog
MG_SYNC_BATCH_SIZE=1000
MG_SYNC_FLUSH_INTERVAL_MS=500
MG_SYNC_RESUME_TOKEN_PATH=/var/lib/mongoflux/resume_tokens
MG_SYNC_MAX_PENDING_ROWS=100000
MG_SYNC_PROPAGATE_DELETES=false
MG_SYNC_DELETE_COLUMN=_deleted

# API
MG_API_PORT=9090
MG_API_BIND=0.0.0.0

# Routing
MG_ROUTING_CLICKHOUSE_PARAM=clickhouse

# Logging
MG_LOG_LEVEL=info
